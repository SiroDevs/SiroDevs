# Copy this file to .env.local and fill in real values.
# The contact form uses these to send mail via your Gmail account.

# Your Gmail address (the one the form sends FROM and TO)
GMAIL_USER=sirodevske@gmail.com

# A Gmail "App Password" — NOT your normal Gmail password.
# Create one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on the account.)
GMAIL_APP_PASSWORD=your16characterapppassword
